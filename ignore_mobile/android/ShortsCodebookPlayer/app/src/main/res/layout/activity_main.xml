<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000">

    <!-- LR 원본 재생 (270×480, 화면 왼쪽 절반) -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerViewLR"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:surface_type="texture_view"
        app:use_controller="false"
        app:resize_mode="fill"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/debugBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/divider" />

    <View
        android:id="@+id/divider"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="#444"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/debugBar"
        app:layout_constraintStart_toEndOf="@id/playerViewLR"
        app:layout_constraintEnd_toStartOf="@id/ivSR" />

    <!-- SR 결과 ImageView (bicubic stub 출력) -->
    <ImageView
        android:id="@+id/ivSR"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitXY"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/debugBar"
        app:layout_constraintStart_toEndOf="@id/divider"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 디버그 정보 바 -->
    <LinearLayout
        android:id="@+id/debugBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textColor="#FFF"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvAssets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Assets: —"
            android:textColor="#8CF"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvMetrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SR: — ms/frame"
            android:textColor="#CF8"
            android:textSize="11sp"
            android:fontFamily="monospace" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
